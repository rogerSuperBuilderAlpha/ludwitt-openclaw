# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/test-results
/playwright-report
*.log

# next.js
/.next/
/out/
.swc/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode/
.idea/
.cursor/
.cursorrules
.cursorignore
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store

# Screenshots
Screenshot*.png
public/Screenshot*

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
firebase-export/

# Firebase Functions (deployed separately)
functions/

# Credentials folder (keep the folder, ignore contents except .gitkeep)
credentials/*
!credentials/.gitkeep

# Legacy paths for credentials (in case they're in root)
*-firebase-adminsdk-*.json
client_secret*.json


# Sentry Config File
.env.sentry-build-plugin
# Playwright auth session
e2e/.auth/

# Internal/deprecated content (should not be re-added)
docs/roadmaps/
docs/archive/
docs/plans/
src/app/deprecated/
src/data/basics/deprecated/
scripts/archive/

