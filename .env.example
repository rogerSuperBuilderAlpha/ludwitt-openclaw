# Firebase Client-side Configuration
# Get these from Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK (Server-side only - NEVER commit to git!)
# Generate from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# GitHub Verification (Optional - for legacy PR verification system)
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_API_TOKEN=ghp_your_github_personal_access_token
GITHUB_VERIFICATION_REPO=username/repo-name

# Anthropic API (Required for AI project generation and Basics Dashboard)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-api-key-here

# D-ID API (Required for video explanations in Basics Dashboard)
# Get from https://studio.d-id.com/account-settings
# Free tier: 20 videos/month, Paid: $49/month for 300 videos
DID_API_KEY=your_did_api_key_here

# Stripe Payments (Required for cohort payment functionality)
# Get from https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=price_xxxxxxxxxxxxx

# Email Configuration (Optional - for notifications and cohort emails)
# Supported providers: sendgrid, mailgun
EMAIL_PROVIDER=mailgun
EMAIL_API_KEY=your_email_api_key
EMAIL_DOMAIN=yourdomain.com
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your App Name

# Learning Study Contact Email (receives study applications)
LEARNING_STUDY_CONTACT_EMAIL=your_email@yourdomain.com

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BOOKING_URL=https://your-booking-url.com

# Access Control (comma-separated email lists)
ADMIN_EMAIL=admin@yourdomain.com
DEVELOPER_EMAILS=dev1@yourdomain.com,dev2@yourdomain.com
DEVELOPER_NOTIFICATION_EMAILS=dev1@yourdomain.com
ADMIN_EMAILS=admin@yourdomain.com
PROFESSOR_EMAILS=professor@yourdomain.com

# Bypass Grant (password for progression bypass)
BYPASS_GRANT_PASSWORD=your_bypass_password

# Reown / WalletConnect (Optional - for Web3 features)
NEXT_PUBLIC_REOWN_PROJECT_ID=your_walletconnect_project_id
REOWN_API_SECRET=your_reown_api_secret
REOWN_WEBHOOK_SECRET=your_reown_webhook_secret

# Google Drive API (Required for Customer Portal)
# Get from https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/customers/auth/callback
